<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UX-CLIENT | Industrial Engine</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;600;700&family=Orbitron:wght@400;700;900&display=swap');

  :root {
    --bg:        #080808;
    --bg2:       #0d0d0d;
    --bg3:       #111;
    --card:      #141414;
    --border:    #1e1e1e;
    --accent:    #00ff78;
    --accent2:   #00c85a;
    --accent3:   #003d20;
    --text:      #e0e0e0;
    --dim:       #555;
    --dim2:      #333;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Rajdhani', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── SCANLINE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,255,120,0.012) 2px,
      rgba(0,255,120,0.012) 4px
    );
    pointer-events: none;
    z-index: 100;
  }

  /* ── GRID BACKGROUND ── */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,255,120,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,120,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 52px;
    background: rgba(8,8,8,0.95);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    z-index: 50;
    backdrop-filter: blur(10px);
  }

  .nav-logo {
    font-family: 'Orbitron', monospace;
    font-weight: 900;
    font-size: 16px;
    color: var(--accent);
    letter-spacing: 3px;
    text-decoration: none;
  }

  .nav-logo span {
    color: var(--dim);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 2px;
    margin-left: 10px;
    font-family: 'Share Tech Mono', monospace;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--dim);
    text-decoration: none;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--accent); }

  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 100px 40px 60px;
    z-index: 1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent3);
    border: 1px solid rgba(0,255,120,0.3);
    color: var(--accent);
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    padding: 6px 16px;
    margin-bottom: 32px;
    animation: fadeDown 0.6s ease both;
  }

  .hero-badge::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 1.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  .hero-title {
    font-family: 'Orbitron', monospace;
    font-weight: 900;
    font-size: clamp(52px, 9vw, 110px);
    line-height: 0.9;
    letter-spacing: -2px;
    margin-bottom: 12px;
    animation: fadeDown 0.6s ease 0.1s both;
  }

  .hero-title .ux { color: var(--accent); }
  .hero-title .client { color: var(--text); }

  .hero-sub {
    font-family: 'Share Tech Mono', monospace;
    font-size: 13px;
    color: var(--dim);
    letter-spacing: 6px;
    text-transform: uppercase;
    margin-bottom: 48px;
    animation: fadeDown 0.6s ease 0.2s both;
  }

  .hero-sub span { color: var(--accent2); }

  /* ── DOWNLOAD BUTTON ── */
  .dl-btn {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    background: var(--accent);
    color: #000;
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 3px;
    padding: 18px 48px;
    text-decoration: none;
    cursor: pointer;
    border: none;
    position: relative;
    overflow: hidden;
    transition: all 0.2s;
    animation: fadeDown 0.6s ease 0.3s both;
    clip-path: polygon(12px 0%, 100% 0%, calc(100% - 12px) 100%, 0% 100%);
  }

  .dl-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.15);
    transform: translateX(-100%);
    transition: transform 0.3s;
  }

  .dl-btn:hover::before { transform: translateX(0); }
  .dl-btn:hover { background: #00e56b; transform: translateY(-2px); box-shadow: 0 12px 40px rgba(0,255,120,0.3); }
  .dl-btn:active { transform: translateY(0); }

  .dl-btn svg { width: 20px; height: 20px; }

  .dl-info {
    margin-top: 16px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--dim);
    letter-spacing: 1px;
    animation: fadeDown 0.6s ease 0.4s both;
  }

  /* ── STATS BAR ── */
  .stats {
    display: flex;
    gap: 60px;
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid var(--border);
    animation: fadeDown 0.6s ease 0.5s both;
  }

  .stat { text-align: center; }

  .stat-num {
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 28px;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--dim);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 6px;
  }

  /* ── FEATURES ── */
  .section {
    position: relative;
    z-index: 1;
    padding: 80px 40px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .section-title {
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 32px;
    color: var(--text);
    margin-bottom: 48px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .feature {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, background 0.2s;
  }

  .feature::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 0;
    background: var(--accent);
    transition: height 0.3s;
  }

  .feature:hover { background: #161616; border-color: var(--dim2); }
  .feature:hover::before { height: 100%; }

  .feature-icon {
    font-size: 28px;
    margin-bottom: 16px;
    display: block;
  }

  .feature-title {
    font-family: 'Orbitron', monospace;
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 1px;
    margin-bottom: 10px;
  }

  .feature-desc {
    font-size: 14px;
    color: var(--dim);
    line-height: 1.6;
    font-weight: 300;
  }

  /* ── INSTALL STEPS ── */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 2px;
    max-width: 700px;
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    background: var(--card);
    border: 1px solid var(--border);
    padding: 24px 28px;
    transition: border-color 0.2s;
  }

  .step:hover { border-color: var(--accent3); }

  .step-num {
    font-family: 'Orbitron', monospace;
    font-weight: 900;
    font-size: 32px;
    color: var(--accent3);
    line-height: 1;
    min-width: 40px;
  }

  .step:hover .step-num { color: var(--accent); }

  .step-content {}

  .step-title {
    font-family: 'Orbitron', monospace;
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
    letter-spacing: 1px;
  }

  .step-desc {
    font-size: 14px;
    color: var(--dim);
    font-weight: 300;
    line-height: 1.5;
  }

  .step-desc code {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    background: var(--bg3);
    color: var(--accent);
    padding: 2px 8px;
    border: 1px solid var(--border);
  }

  /* ── VERSIONS ── */
  .versions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
    gap: 4px;
    margin-top: 8px;
  }

  .version-chip {
    background: var(--bg3);
    border: 1px solid var(--border);
    padding: 8px 10px;
    text-align: center;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--dim);
    transition: all 0.15s;
    cursor: default;
  }

  .version-chip:hover { background: var(--accent3); color: var(--accent); border-color: rgba(0,255,120,0.3); }
  .version-chip.latest { background: var(--accent3); color: var(--accent); border-color: rgba(0,255,120,0.4); }

  /* ── FOOTER ── */
  footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border);
    padding: 32px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-logo {
    font-family: 'Orbitron', monospace;
    font-size: 14px;
    color: var(--accent);
    letter-spacing: 2px;
  }

  .footer-text {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--dim);
    letter-spacing: 1px;
  }

  /* ── TERMINAL WINDOW ── */
  .terminal {
    background: #060606;
    border: 1px solid var(--border);
    border-top: 2px solid var(--accent);
    max-width: 680px;
    margin: 48px auto 0;
  }

  .terminal-bar {
    background: #0d0d0d;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--border);
  }

  .t-dot { width: 10px; height: 10px; border-radius: 50%; }
  .t-dot.red   { background: #ff5555; }
  .t-dot.yellow{ background: #ffb800; }
  .t-dot.green { background: var(--accent); }

  .terminal-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--dim);
    margin-left: 8px;
    letter-spacing: 1px;
  }

  .terminal-body {
    padding: 20px 24px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    line-height: 1.8;
  }

  .t-green { color: var(--accent); }
  .t-dim   { color: var(--dim); }
  .t-white { color: var(--text); }
  .t-blue  { color: #64b5ff; }

  /* ── DOWNLOAD SECTION ── */
  .dl-section {
    position: relative;
    z-index: 1;
    background: linear-gradient(180deg, transparent, rgba(0,255,120,0.03), transparent);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 80px 40px;
    text-align: center;
  }

  .dl-cards {
    display: flex;
    gap: 2px;
    justify-content: center;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .dl-card {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 32px 40px;
    min-width: 220px;
    text-align: center;
    transition: all 0.2s;
    cursor: pointer;
    text-decoration: none;
    display: block;
  }

  .dl-card:hover {
    background: #161616;
    border-color: var(--accent3);
    transform: translateY(-4px);
  }

  .dl-card.primary { border-color: rgba(0,255,120,0.3); }
  .dl-card.primary:hover { border-color: var(--accent); }

  .dl-card-icon { font-size: 32px; margin-bottom: 12px; display: block; }

  .dl-card-title {
    font-family: 'Orbitron', monospace;
    font-size: 12px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .dl-card.primary .dl-card-title { color: var(--accent); }

  .dl-card-sub {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--dim);
    letter-spacing: 1px;
  }

  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── GLOW ORBS ── */
  .orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
    opacity: 0.12;
  }
  .orb1 { width: 600px; height: 600px; background: var(--accent); top: -200px; left: -200px; }
  .orb2 { width: 400px; height: 400px; background: var(--accent); bottom: -100px; right: -100px; }
</style>
</head>
